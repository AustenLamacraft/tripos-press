# PostgreSQL — use Neon (neon.tech) for managed hosting
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/tripos_press?sslmode=require"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# GitHub OAuth app (github.com/settings/developers)
AUTH_GITHUB_ID="your-github-oauth-app-id"
AUTH_GITHUB_SECRET="your-github-oauth-app-secret"

# Public URL (set to production URL when deploying)
NEXTAUTH_URL="http://localhost:3000"
